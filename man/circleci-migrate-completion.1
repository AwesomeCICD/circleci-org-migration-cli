.nh
.TH "CIRCLECI-MIGRATE" "1" "Jun 2026" "circleci-migrate" "CircleCI Org Migration CLI"

.SH NAME
circleci-migrate-completion - Generate the autocompletion script for the specified shell


.SH SYNOPSIS
\fBcircleci-migrate completion [flags]\fP


.SH DESCRIPTION
Generate the autocompletion script for circleci-migrate for the specified shell.
See each sub-command's help for details on how to use the generated script.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug logging

.PP
\fB--dest-token\fP=""
	API token for the destination org (env: CIRCLECI_DEST_TOKEN)

.PP
\fB--host\fP="https://circleci.com"
	CircleCI host URL (env: CIRCLECI_HOST)

.PP
\fB--source-token\fP=""
	API token for the source org (env: CIRCLECI_SOURCE_TOKEN)

.PP
\fB--token\fP=""
	Personal API token — fallback for both orgs (env: CIRCLECI_CLI_TOKEN)


.SH SEE ALSO
\fBcircleci-migrate(1)\fP, \fBcircleci-migrate-completion-bash(1)\fP, \fBcircleci-migrate-completion-fish(1)\fP, \fBcircleci-migrate-completion-powershell(1)\fP, \fBcircleci-migrate-completion-zsh(1)\fP
