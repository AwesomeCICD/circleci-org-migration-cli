.nh
.TH "CIRCLECI-MIGRATE" "1" "Jun 2026" "circleci-migrate" "CircleCI Org Migration CLI"

.SH NAME
circleci-migrate-version - Display version and build information.


.SH SYNOPSIS
\fBcircleci-migrate version [flags]\fP


.SH DESCRIPTION
Prints the version number, git commit SHA, and OS/architecture of this build.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for version


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug logging

.PP
\fB--dest-token\fP=""
	API token for the destination org (env: CIRCLECI_DEST_TOKEN)

.PP
\fB--host\fP="https://circleci.com"
	CircleCI host URL (env: CIRCLECI_CLI_HOST, CIRCLECI_HOST, or CIRCLE_URL)

.PP
\fB--source-token\fP=""
	API token for the source org (env: CIRCLECI_SOURCE_TOKEN)

.PP
\fB--token\fP=""
	Personal API token — fallback for both orgs (env: CIRCLECI_CLI_TOKEN or CIRCLE_TOKEN)


.SH SEE ALSO
\fBcircleci-migrate(1)\fP
