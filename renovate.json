{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 0,
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": [
      "dependencies",
      "security",
      "priority:high"
    ],
    "automerge": false
  },
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "groupName": "go modules",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "matchManagers": [
        "circleci"
      ],
      "groupName": "circleci orbs"
    },
    {
      "description": "Group the Go toolchain bumps separately so they are easy to review.",
      "matchManagers": [
        "gomod"
      ],
      "matchDepTypes": [
        "golang"
      ],
      "groupName": "go toolchain"
    },
    {
      "description": "lipgloss v2 is a breaking rewrite (new /v2 import path + changed API); v1 is stable and sufficient for our styled help. Don't propose major bumps.",
      "matchPackageNames": [
        "github.com/charmbracelet/lipgloss"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "description": "Keep pinned tool versions in CI config / Makefile up to date (goreleaser, trivy, gitleaks, golangci-lint).",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.circleci/config\\.yml$/",
        "/^\\.circleci/continue_config\\.yml$/",
        "/^Makefile$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+?)\\s+depName=(?<depName>.+?)\\s*\\n.*?(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "versioningTemplate": "semver"
    }
  ]
}
