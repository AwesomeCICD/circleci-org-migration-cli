{
  "commands": [
    {
      "name": "format",
      "run": "gofmt -w .",
      "role": "autofix",
      "timeout": 30,
      "limit": 3,
      "always": true
    },
    {
      "name": "vet",
      "run": "go vet ./...",
      "role": "precheck",
      "fileExt": ".go",
      "timeout": 60,
      "limit": 3
    },
    {
      "name": "build",
      "run": "go build ./...",
      "role": "precheck",
      "fileExt": ".go",
      "timeout": 120,
      "limit": 3
    },
    {
      "name": "test-changed",
      "run": "go test {{CHANGED_PACKAGES}}",
      "role": "precheck",
      "fileExt": ".go",
      "timeout": 120,
      "limit": 3
    },
    {
      "name": "lint",
      "run": "make lint",
      "role": "gate",
      "fileExt": ".go",
      "timeout": 180,
      "limit": 2
    },
    {
      "name": "test",
      "run": "make test",
      "role": "gate",
      "fileExt": ".go",
      "timeout": 300,
      "limit": 2
    },
    {
      "name": "security",
      "run": "make security",
      "role": "gate",
      "fileExt": ".go",
      "timeout": 300,
      "limit": 2
    },
    {
      "name": "config-validate",
      "run": "make config-validate",
      "role": "gate",
      "fileExt": ".yml",
      "timeout": 60,
      "limit": 2
    },
    {
      "name": "orb-config-validate",
      "run": "circleci config validate .circleci/config.yml && circleci config validate --org-id efc130dc-284f-4533-964e-844f5c173860 .circleci/continue_config.yml",
      "role": "gate",
      "fileExt": ".yml",
      "timeout": 60,
      "limit": 2
    },
    {
      "name": "orb-pack-validate",
      "run": "circleci orb pack orb/src > /tmp/orb.yml && circleci orb validate --org-id efc130dc-284f-4533-964e-844f5c173860 /tmp/orb.yml",
      "role": "gate",
      "fileExt": ".yml",
      "timeout": 60,
      "limit": 2
    },
    {
      "name": "orb-shellcheck",
      "run": "shellcheck -e SC2148 -e SC2086 -e SC2016 -e SC2002 orb/src/scripts/*.sh",
      "role": "gate",
      "fileExt": ".sh",
      "timeout": 60,
      "limit": 2
    }
  ],
  "vcs": {
    "org": "AwesomeCICD",
    "repo": "circleci-org-migration-cli"
  },
  "environment": {
    "stack": "go",
    "image": "cimg/go",
    "image_version": "1.26.4",
    "setup": [
      {
        "name": "install",
        "command": "go mod download"
      }
    ]
  }
}
