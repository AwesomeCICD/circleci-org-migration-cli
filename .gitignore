/bin/
/dist/

# Test coverage & scan reports
*.out
coverage.txt
coverage.html
/test-results/
*.sarif

# Personal Claude Code settings (shared settings.json is committed)
/.claude/settings.local.json

# Generated CLI output (manifests, reports, secret bundles) — never commit
/manifest.json
/migration-report.md
/secrets.json
*.manifest.json
/bin/circleci-migrate

# age encryption keys (never commit)
*.age
/migration-identity.age
/migration-recipient.txt

# Packed orb — generated from orb/src/ by `circleci orb pack orb/src`
# orb/src/ is the source of truth; this file is regenerated on demand.
/orb/orb.yml

# Agent worktrees (transient; never commit)
.claude/worktrees/
